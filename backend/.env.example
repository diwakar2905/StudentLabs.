# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# SQLite (default - no setup needed)
DATABASE_URL=sqlite:///./student_labs.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://username:password@localhost:5432/studentlabs

# Connection pooling
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false  # Set to true for SQL logging

# ==============================================================================
# CACHE & MESSAGE BROKER
# ==============================================================================

# Redis URL for Celery and caching
REDIS_URL=redis://localhost:6379/0

# Redis options
REDIS_RETRY_ON_TIMEOUT=true
REDIS_MAX_CONNECTIONS=20

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Debug mode (disable in production)
DEBUG=false

# Environment
ENVIRONMENT=development  # or production

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================

# Allowed origins for CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "https://studentlabs.com"]

# CORS credentials
CORS_ALLOW_CREDENTIALS=true

# ==============================================================================
# AI MODEL CONFIGURATION
# ==============================================================================

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Generation model
GENERATION_MODEL=mistralai/Mistral-7B-Instruct

# Summarization model
SUMMARIZATION_MODEL=facebook/bart-large-cnn

# Model cache directory
MODELS_DIR=./models

# ==============================================================================
# STORAGE CONFIGURATION
# ==============================================================================

# FAISS index storage
FAISS_INDEXES_DIR=./faiss_indexes

# Temporary files
TEMP_DIR=/tmp/studentlabs

# ==============================================================================
# TIMEOUT CONFIGURATION
# ==============================================================================

# Task timeouts (in seconds)
GENERATION_TIMEOUT=1800  # 30 minutes
RETRIEVAL_TIMEOUT=30     # 30 seconds
INDEX_LOAD_TIMEOUT=60    # 1 minute

# ==============================================================================
# CELERY CONFIGURATION
# ==============================================================================

# Celery broker URL (same as REDIS_URL for Redis broker)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Task retry settings
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=60  # seconds

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================

# Log level
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Log file
LOG_FILE=./logs/app.log

# Enable SQL logging (verbose)
SQL_LOGGING=false

# ==============================================================================
# SECURITY
# ==============================================================================

# Secret key for JWT tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-at-least-32-chars

# JWT token expiration (in hours)
JWT_EXPIRATION_HOURS=24

# API key authentication (optional)
API_KEY=your-api-key-here

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Enable/disable features
USE_RAG=true
USE_ASYNC_TASKS=true
USE_CACHING=true
USE_PRETTY_ERRORS=true

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================

# Sentry for error tracking
SENTRY_DSN=

# OpenAI API (if using external LLM)
OPENAI_API_KEY=

# Email service (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@studentlabs.com
